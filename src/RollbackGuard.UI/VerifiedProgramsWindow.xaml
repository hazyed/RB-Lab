<Window x:Class="RollbackGuard.UI.VerifiedProgramsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="已验证程序"
        Width="1220"
        Height="720"
        MinWidth="980"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBackground}"
        FontFamily="Segoe UI Variable Text, Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Padding="18">
            <StackPanel>
                <TextBlock Text="已验证程序"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushTextMain}"/>
                <TextBlock Text="这里单独查看所有已验证程序，并同时展示内核与用户态的签名判断。"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource BrushTextSub}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Padding="0"
                ClipToBounds="True">
            <Grid>
                <ListView ItemsSource="{Binding VerifiedPrograms}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">
                            <GridViewColumn Header="程序名" Width="170" DisplayMemberBinding="{Binding ProcessName}"/>
                            <GridViewColumn Header="综合分级" Width="110" DisplayMemberBinding="{Binding TrustDisplay}"/>
                            <GridViewColumn Header="内核判定" Width="110" DisplayMemberBinding="{Binding KernelTrustDisplay}"/>
                            <GridViewColumn Header="用户态判定" Width="110" DisplayMemberBinding="{Binding UserModeTrustDisplay}"/>
                            <GridViewColumn Header="最近观察" Width="120" DisplayMemberBinding="{Binding LastSeen}"/>
                            <GridViewColumn Header="路径" Width="640" DisplayMemberBinding="{Binding ProcessPath}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <TextBlock Text="{Binding VerifiedProgramsHint}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource BrushTextSub}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="20"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding VerifiedPrograms.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
