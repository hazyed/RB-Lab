<Window x:Class="RollbackGuard.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RollbackGuard Console"
        Width="1400"
        Height="900"
        MinWidth="1200"
        MinHeight="768"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackground}"
        FontFamily="Segoe UI Variable Text, Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="White"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,1,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="28" Height="28" Margin="0,0,10,0">
                            <Path Data="{StaticResource IconShield}" Fill="{StaticResource BrushPrimary}"/>
                        </Viewbox>
                        <TextBlock Text="RollbackGuard"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrushTextMain}"/>
                    </StackPanel>
                    <TextBlock Text="反勒索与威胁缓解系统"
                               Margin="38,4,0,0"
                               Foreground="{StaticResource BrushTextSub}"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,24">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="12">
                        <DockPanel>
                            <Viewbox Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Top" DockPanel.Dock="Left">
                                <Path Data="{StaticResource IconShield}" Fill="{StaticResource BrushPrimaryDark}"/>
                            </Viewbox>
                            <StackPanel>
                                <TextBlock Text="驱动核心"
                                           FontSize="11"
                                           Foreground="{StaticResource BrushTextSub}"/>
                                <TextBlock Text="{Binding DriverState}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Margin="0,2,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="12">
                        <DockPanel>
                            <Viewbox Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Top" DockPanel.Dock="Left">
                                <Path Data="{StaticResource IconPolicy}" Fill="{StaticResource BrushSuccess}"/>
                            </Viewbox>
                            <StackPanel>
                                <TextBlock Text="防护策略"
                                           FontSize="11"
                                           Foreground="{StaticResource BrushTextSub}"/>
                                <TextBlock Text="{Binding PolicyVersion}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="12">
                        <DockPanel>
                            <Viewbox Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Top" DockPanel.Dock="Left">
                                <Path Data="{StaticResource IconActivity}" Fill="{StaticResource BrushWarning}"/>
                            </Viewbox>
                            <StackPanel>
                                <TextBlock Text="最近系统活动"
                                           FontSize="11"
                                           Foreground="{StaticResource BrushTextSub}"/>
                                <TextBlock Text="{Binding LastAction}"
                                           FontSize="13"
                                           FontWeight="Normal"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           LineHeight="18"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="白名单程序"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextSub}"
                               Margin="0,0,0,10"/>

                    <Border Grid.Row="1"
                            Background="{StaticResource BrushBackground}"
                            CornerRadius="6"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1">
                        <StackPanel Margin="14">
                            <DockPanel Margin="0,0,0,10">
                                <Viewbox Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" DockPanel.Dock="Left">
                                    <Path Data="{StaticResource IconCheck}" Fill="{StaticResource BrushSuccess}"/>
                                </Viewbox>
                                <TextBlock Text="单独窗口查看"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushTextMain}"/>
                            </DockPanel>

                            <TextBlock Text="{Binding VerifiedPrograms.Count, StringFormat=当前已验证 {0} 个程序。}"
                                       Foreground="{StaticResource BrushTextMain}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding VerifiedProgramsHint}"
                                       Foreground="{StaticResource BrushTextSub}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <Button Style="{StaticResource ModernBtn}"
                                    Click="OnOpenVerifiedProgramsClick"
                                    Height="38">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                        <Path Data="{StaticResource IconActivity}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Viewbox>
                                    <TextBlock Text="打开白名单程序"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <Button Grid.Row="3"
                        Margin="0,16,0,0"
                        Style="{StaticResource ModernBtn}"
                        Click="OnRefreshClick"
                        Height="40">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                            <Path Data="{StaticResource IconRefresh}"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Viewbox>
                        <TextBlock Text="刷新全局日志"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="威胁处置日志中心"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushTextMain}"/>
                    <TextBlock Text="查看并管理被拦截的勒索行为、内存注入及可疑操作记录。"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource BrushTextSub}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryBtn}" Click="OnRefreshClick" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                                <Path Data="{StaticResource IconRefresh}" Fill="White"/>
                            </Viewbox>
                            <TextBlock Text="刷新"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ModernBtn}" Click="OnDeleteSelectedClick" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                                <Path Data="{StaticResource IconDelete}" Fill="{StaticResource BrushTextSub}"/>
                            </Viewbox>
                            <TextBlock Text="删除选中"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DangerBtn}" Click="OnClearAllClick">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                                <Path Data="{StaticResource IconClear}" Fill="{StaticResource BrushDanger}"/>
                            </Viewbox>
                            <TextBlock Text="清空所有"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Separator Grid.Row="1" Margin="0,16" Background="{StaticResource BrushBorder}"/>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.2*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                    <Grid>
                        <ListView ItemsSource="{Binding IncidentRows}"
                                  SelectedItem="{Binding SelectedIncident, Mode=TwoWay}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.View>
                                <GridView AllowsColumnReorder="False">
                                    <GridViewColumn Header="时间" Width="150" DisplayMemberBinding="{Binding Time}"/>
                                    <GridViewColumn Header="PID" Width="70" DisplayMemberBinding="{Binding ProcessId}"/>
                                    <GridViewColumn Header="进程名" Width="140" DisplayMemberBinding="{Binding ProcessName}"/>
                                    <GridViewColumn Header="动作" Width="80">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Action}"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource BrushPrimary}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="分值" Width="60" DisplayMemberBinding="{Binding Score, StringFormat={}{0:F1}}"/>
                                    <GridViewColumn Header="判定事件" Width="140" DisplayMemberBinding="{Binding ThreatType}"/>
                                    <GridViewColumn Header="已杀进程" Width="80" DisplayMemberBinding="{Binding KillStatus}"/>
                                    <GridViewColumn Header="已回滚" Width="90" DisplayMemberBinding="{Binding RollbackStatus}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IncidentRows.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Viewbox Width="48" Height="48" Margin="0,0,0,16" Opacity="0.3">
                                <Path Data="{StaticResource IconActivity}" Fill="Gray"/>
                            </Viewbox>
                            <TextBlock Text="{Binding NoDataHint}"
                                       Foreground="{StaticResource BrushTextSub}"
                                       FontSize="16"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardStyle}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#FAFAFA"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,12"
                                    CornerRadius="8,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedIncidentTitle}"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource BrushTextMain}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding SelectedIncidentPath}"
                                               Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource BrushTextSub}"
                                               FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>

                            <TabControl Grid.Row="1" Margin="8">
                                <TabItem Header="事件概览">
                                    <TextBox Text="{Binding SelectedIncidentDetail, Mode=OneWay}"
                                             Style="{DynamicResource DetailTextBoxStyle}"/>
                                </TabItem>
                                <TabItem Header="内存详情">
                                    <TextBox Text="{Binding SelectedIncidentMemoryDetail, Mode=OneWay}"
                                             Style="{DynamicResource DetailTextBoxStyle}"/>
                                </TabItem>
                                <TabItem Header="DLL 加载列表">
                                    <TextBox Text="{Binding SelectedIncidentDllList, Mode=OneWay}"
                                             Style="{DynamicResource DetailTextBoxStyle}"/>
                                </TabItem>
                                <TabItem Header="清除与回滚">
                                    <TextBox Text="{Binding SelectedIncidentRemediation, Mode=OneWay}"
                                             Style="{DynamicResource DetailTextBoxStyle}"/>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid.Resources>
            <Style x:Key="DetailTextBoxStyle" TargetType="TextBox">
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="AcceptsReturn" Value="True"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="FontFamily" Value="Consolas, Cascadia Code, Courier New"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource BrushTextMain}"/>
            </Style>
        </Grid.Resources>
    </Grid>
</Window>
